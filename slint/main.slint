// AllInOnePolyglotAIJDK - Slint UI
// Mirrors the core chat + environment + deploy-log layout of the QML version.

import { Button, LineEdit, ScrollView, ComboBox } from "std-widgets.slint";

export struct ChatMessage {
    text: string,
    is-user: bool,
}

export component MainWindow inherits Window {
    title: "AllInOnePolyglotAIJDK v3.3 - Slint";
    width: 1280px;
    height: 800px;
    background: #0a0a0a;

    // ── callbacks called from Python ─────────────────────────────────────────
    callback send-message(string);
    callback set-environment(string);

    // ── properties written from Python ───────────────────────────────────────
    in-out property <[ChatMessage]> chat-messages: [];
    in-out property <string> deploy-log: "";
    in-out property <string> status-text: "Ready";

    // ── colours ──────────────────────────────────────────────────────────────
    property <color> accent: #00ff9d;
    property <color> bg-panel: #111111;
    property <color> fg-text: #e0e0e0;

    HorizontalLayout {
        padding: 12px;
        spacing: 12px;

        // ── LEFT: Chat panel ─────────────────────────────────────────────────
        Rectangle {
            width: 480px;
            background: bg-panel;
            border-radius: 14px;

            VerticalLayout {
                padding: 16px;
                spacing: 12px;

                // Environment selector
                Text {
                    text: "Environment";
                    color: accent;
                    font-size: 12px;
                }

                ComboBox {
                    model: ["java", "python", "javascript", "rust", "csharp", "go"];
                    selected => {
                        root.set-environment(self.current-value);
                    }
                }

                // Chat history
                ScrollView {
                    vertical-stretch: 1;

                    VerticalLayout {
                        spacing: 10px;
                        for msg in root.chat-messages: Rectangle {
                            background: msg.is-user ? #1a2a1a : #1a1a2a;
                            border-radius: 8px;

                            VerticalLayout {
                                padding: 10px;

                                Text {
                                    text: msg.text;
                                    color: fg-text;
                                    font-size: 13px;
                                    wrap: word-wrap;
                                }
                            }
                        }
                    }
                }

                // Input row
                HorizontalLayout {
                    spacing: 8px;

                    chat-input := LineEdit {
                        placeholder-text: "Send directions to the Agent...";
                        horizontal-stretch: 1;
                        accepted => {
                            root.send-message(self.text);
                            self.text = "";
                        }
                    }

                    Button {
                        text: "SEND";
                        clicked => {
                            root.send-message(chat-input.text);
                            chat-input.text = "";
                        }
                    }
                }

                // Status bar
                Text {
                    text: root.status-text;
                    color: #888888;
                    font-size: 11px;
                }
            }
        }

        // ── RIGHT: Deploy log ────────────────────────────────────────────────
        Rectangle {
            horizontal-stretch: 1;
            background: bg-panel;
            border-radius: 14px;

            VerticalLayout {
                padding: 16px;
                spacing: 10px;

                Text {
                    text: "Deploy / Agent Log";
                    color: accent;
                    font-size: 12px;
                }

                ScrollView {
                    vertical-stretch: 1;

                    Text {
                        text: root.deploy-log;
                        color: fg-text;
                        font-size: 12px;
                        font-family: "Consolas";
                        wrap: word-wrap;
                    }
                }
            }
        }
    }
}
